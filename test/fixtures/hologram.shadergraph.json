{
  "nodes": [
    {
      "id": "uv",
      "type": "uv"
    },
    {
      "id": "time",
      "type": "time"
    },
    {
      "id": "base",
      "type": "baseTexture"
    },
    {
      "id": "tint",
      "type": "parameter",
      "properties": {
        "name": "tint",
        "default": [0.1, 0.8, 1.0, 1.0]
      }
    },
    {
      "id": "tinted",
      "type": "multiply",
      "inputs": {
        "a": "base",
        "b": "tint"
      }
    },
    {
      "id": "fresnelPower",
      "type": "constant",
      "properties": {
        "value": 3.0
      }
    },
    {
      "id": "rim",
      "type": "fresnel",
      "inputs": {
        "power": "fresnelPower"
      }
    },
    {
      "id": "emissiveTint",
      "type": "constant",
      "properties": {
        "value": [0.0, 0.6, 1.0]
      }
    },
    {
      "id": "emissive",
      "type": "multiply",
      "inputs": {
        "a": "emissiveTint",
        "b": "rim"
      }
    },
    {
      "id": "scroll",
      "type": "combine2",
      "inputs": {
        "x": "time",
        "y": "time"
      }
    },
    {
      "id": "animatedUv",
      "type": "add",
      "inputs": {
        "a": "uv",
        "b": "scroll"
      }
    },
    {
      "id": "noise",
      "type": "noise2d",
      "inputs": {
        "uv": "animatedUv"
      }
    }
  ],
  "output": {
    "baseColor": "tinted",
    "opacity": "noise",
    "emissive": "emissive"
  }
}

